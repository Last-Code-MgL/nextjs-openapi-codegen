{
  "name": "nextjs-openapi-codegen",
  "version": "1.0.1",
  "description": "CLI to generate Next.js API route handlers, typed frontend services, apiClient and fetchBackend from any OpenAPI/Swagger spec",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "nextjs-codegen": "./bin/cli.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "author": "Miguel thelastcodee@gmail.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Last-Code-MgL/nextjs-openapi-codegen.git"
  },
  "homepage": "https://github.com/Last-Code-MgL/nextjs-openapi-codegen#readme",
  "bugs": {
    "url": "https://github.com/Last-Code-MgL/nextjs-openapi-codegen/issues"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsup": "^8.0.0",
    "@types/node": "^20.0.0"
  },
  "keywords": [
    "nextjs",
    "openapi",
    "swagger",
    "codegen",
    "cli",
    "routes",
    "services",
    "typescript"
  ],
  "license": "MIT"
}
